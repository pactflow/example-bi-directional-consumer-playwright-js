# Base URL of the provider API.
#
# Playwright intercepts every request to this origin, so nothing actually listens
# here during a test run. It does need to be identical in src/api.ts, the specs,
# the Makefile and CI, or interception silently misses and no contract is written.
VITE_API_BASE_URL=http://localhost:8080

# Which provider the generated contract is published against.
PACT_PROVIDER=pactflow-example-bi-directional-provider-dredd

# Required for publishing contracts to PactFlow (see README).
# PACT_BROKER_BASE_URL=https://your-domain.pactflow.io
# PACT_BROKER_TOKEN=your-token-here
